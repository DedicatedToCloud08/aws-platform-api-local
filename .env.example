# =============================================================================
# Database
# =============================================================================
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme_in_real_use
POSTGRES_DB=appdb

# =============================================================================
# AWS (only used when running against AWS Secrets Manager — usually unset locally)
# =============================================================================
AWS_REGION=eu-west-1

# =============================================================================
# pgAdmin (debug profile only)
# =============================================================================
PGADMIN_EMAIL=admin@localhost
PGADMIN_PASSWORD=admin

# =============================================================================
# Grafana Monitoring (monitoring profile only)
# =============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin