# =============================================================================
# Version control
# =============================================================================
.git/
.gitignore
.gitattributes
.github/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
.coverage
htmlcov/

# =============================================================================
# Secrets — CRITICAL: never bake these into images
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials.json
aws-credentials*

# =============================================================================
# Tests — exclude from PROD image (kept in dev via bind mount)
# =============================================================================
app/tests/

# =============================================================================
# Docker / Compose orchestration files — not needed inside the image
# =============================================================================
docker-compose*.yml
docker-compose*.yaml
Makefile
docker/init.sql

# =============================================================================
# Monitoring configs — these belong on the host, not in the API image
# =============================================================================
monitoring/

# =============================================================================
# Dev tooling & docs
# =============================================================================
README.md
docs/
*.md
.vscode/
.idea/
*.swp

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# Logs & local artifacts
# =============================================================================
*.log
logs/
*.bak
*.tmp